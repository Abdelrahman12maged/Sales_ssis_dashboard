              "dataSource": "SqlServer DESKTOP-IC98GCVSQLDEV sales_DWH"
            }
          }
        ],
        "measures": [
          {
            "name": "Total Sales",
            "expression": " SUM(Fact_Sales[sales])"
          },
          {
            "name": "Total Profit",
            "expression": " SUM(Fact_Sales[profit])"
          },
          {
            "name": "Total Quantity",
            "expression": " SUM(Fact_Sales[quantity])"
          },
          {
            "name": "Total Orders",
            "expression": " DISTINCTCOUNT(Fact_Sales[Fact_Sales_Key])"
          },
          {
            "name": "Profit Margin %",
            "expression": [
              " DIVIDE([Total Profit], [Total Sales], 0)",
              ""
            ]
          },
          {
            "name": "Average Order Value",
            "expression": [
              " DIVIDE([Total Sales], DISTINCTCOUNT(Fact_Sales[Order_id]), 0)",
              ""
            ]
          },
          {
            "name": "Average Discount",
            "expression": [
              " AVERAGE(Fact_Sales[discount])",
              ""
            ]
          },
          {
            "name": "Total Active Customers",
            "expression": [
              " DISTINCTCOUNT(Fact_Sales[CustomerID])",
              ""
            ]
          },
          {
            "name": "Sales per Customer",
            "expression": [
              " DIVIDE([Total Sales], [Total Active Customers], 0)",
              ""
            ]
          },
          {
            "name": "Unique Products Sold",
            "expression": [
              " DISTINCTCOUNT(Fact_Sales[Product_key])",
              ""
            ]
          }
        ],
